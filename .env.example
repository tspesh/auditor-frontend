# Supabase (required for auth and data). Use build-time env in production (e.g. Cloudflare Pages).
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# Use either: legacy anon key (JWT) from Dashboard → API → anon, or new publishable key (sb_publishable_...) from API Keys tab.
PUBLIC_SUPABASE_ANON_KEY=eyJ...
# PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # optional; modern key, same privileges as anon

# Backend API URL. Leave empty for local dev (Vite proxies /api to backend). REQUIRED in production:
# set to your Fly backend URL (e.g. https://auditor.fly.dev) so /api/v1/* requests go to the backend, not the frontend.
PUBLIC_API_URL=
