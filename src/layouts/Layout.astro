---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Build-time: use env if set; otherwise use placeholders so Cloudflare Worker can inject at runtime (Variables and Secrets).
const SUPABASE_PLACEHOLDER_URL = '__PUBLIC_SUPABASE_URL__';
const SUPABASE_PLACEHOLDER_KEY = '__PUBLIC_SUPABASE_ANON_KEY__';
const supabaseUrl =
  (typeof process !== 'undefined' && process.env?.PUBLIC_SUPABASE_URL) ||
  import.meta.env.PUBLIC_SUPABASE_URL ||
  SUPABASE_PLACEHOLDER_URL;
const supabaseAnonKey =
  (typeof process !== 'undefined' && (process.env?.PUBLIC_SUPABASE_ANON_KEY || process.env?.PUBLIC_SUPABASE_PUBLISHABLE_KEY)) ||
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ||
  import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
  SUPABASE_PLACEHOLDER_KEY;
---

<!doctype html>
<html lang="en">
  <head>
    <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
      window.__SUPABASE_ENV__ = { url: supabaseUrl, anonKey: supabaseAnonKey };
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-T37JV8Q4');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-neutral-100 text-neutral-800">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T37JV8Q4"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="bg-neutral-900 text-neutral-0">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-heading text-xl font-bold tracking-tight">
          <span class="text-growth-500">Auditor</span>
          <span class="text-neutral-400 font-normal text-caption ml-2">by Better Off Growth</span>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-neutral-900 text-neutral-400 mt-24">
      <div class="container mx-auto px-6 py-8 text-center text-sm">
        <p>&copy; {new Date().getFullYear()} Better Off Growth. All Rights Reserved.</p>
      </div>
    </footer>
  </body>
</html>
