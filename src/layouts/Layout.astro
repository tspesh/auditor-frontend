---
import '../styles/global.css';
import { ViewTransitions, fade } from 'astro:transitions';
import Nav from '../components/Nav';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Build-time: use env if set; otherwise use placeholders so Cloudflare Worker can inject at runtime (Variables and Secrets).
const SUPABASE_PLACEHOLDER_URL = '__PUBLIC_SUPABASE_URL__';
const SUPABASE_PLACEHOLDER_KEY = '__PUBLIC_SUPABASE_ANON_KEY__';
const supabaseUrl =
  (typeof process !== 'undefined' && process.env?.PUBLIC_SUPABASE_URL) ||
  import.meta.env.PUBLIC_SUPABASE_URL ||
  SUPABASE_PLACEHOLDER_URL;
const supabaseAnonKey =
  (typeof process !== 'undefined' && (process.env?.PUBLIC_SUPABASE_ANON_KEY || process.env?.PUBLIC_SUPABASE_PUBLISHABLE_KEY)) ||
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ||
  import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
  SUPABASE_PLACEHOLDER_KEY;
---

<!doctype html>
<html lang="en">
  <head>
    <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
      window.__SUPABASE_ENV__ = { url: supabaseUrl, anonKey: supabaseAnonKey };
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="flex flex-col min-h-screen bg-neutral-100 text-neutral-800">
    <Nav client:load transition:persist />

    <main class="flex-1" transition:animate={fade({ duration: '0.15s' })}>
      <slot />
    </main>

    <footer class="bg-neutral-900 text-neutral-400 mt-auto pt-24" transition:animate="none">
      <div class="container mx-auto px-6 py-8 text-center text-sm">
        <p>&copy; {new Date().getFullYear()} Better Off Growth. All Rights Reserved.</p>
      </div>
    </footer>
  </body>
</html>
